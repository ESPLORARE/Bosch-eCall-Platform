# Server-only secrets.
# Do NOT prefix secrets with VITE_ and do NOT inject them into the frontend bundle.
# Keep real values in .env.local or your hosting platform secret manager.
GEMINI_API_KEY="MY_SERVER_ONLY_API_KEY"

# Local persistent database path. Defaults to ./data/bosch-ecall-platform.sqlite.
DATABASE_PATH="./data/bosch-ecall-platform.sqlite"

# Public build/runtime settings that are safe to expose to the browser can use VITE_.
VITE_BASE_PATH="/Bosch-eCall-Platform/"
